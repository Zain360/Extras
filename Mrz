import cv2
import numpy as np
import imutils
import matplotlib.pyplot as plt

def crop_and_straighten(image, rect):
    """
    Takes a rotated rectangle (minAreaRect), rotates the image 
    to make the text horizontal, and crops it.
    """
    center, size, angle = rect
    center, size = tuple(map(int, center)), tuple(map(int, size))
    
    width, height = size
    if width < height:
        angle += 90
        width, height = height, width

    M = cv2.getRotationMatrix2D(center, angle, 1.0)
    h, w = image.shape[:2]
    rotated_img = cv2.warpAffine(image, M, (w, h), flags=cv2.INTER_CUBIC, borderMode=cv2.BORDER_REPLICATE)
    
    x = int(center[0] - width / 2)
    y = int(center[1] - height / 2)
    
    # Safety check to prevent negative slicing
    y = max(0, y)
    x = max(0, x)
    
    cropped = rotated_img[y:y+height, x:x+width]
    return cropped

def trim_horizontal_padding(image, padding=3):
    """
    Trims empty left/right space from a STRAIGHTENED text image.
    """
    if image is None or image.size == 0: return image
    
    gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)
    _, thresh = cv2.threshold(gray, 0, 255, cv2.THRESH_BINARY_INV | cv2.THRESH_OTSU)
    
    col_sum = np.sum(thresh, axis=0)
    indices = np.where(col_sum > 0)[0]
    
    if len(indices) == 0: return image

    x_start = indices[0]
    x_end = indices[-1]

    x_start = max(0, x_start - padding)
    x_end = min(image.shape[1], x_end + padding)

    return image[:, x_start:x_end]

def detect_rotated_mrz(image_path):
    # 1. Load
    image = cv2.imread(image_path)
    if image is None: 
        print(f"Error: Could not load {image_path}")
        return None, []
    
    original = image.copy()
    
    # Resize
    processing_img = imutils.resize(image, width=1000)
    ratio = image.shape[1] / 1000.0

    # 2. Texture Detection
    gray = cv2.cvtColor(processing_img, cv2.COLOR_BGR2GRAY)
    gray = cv2.GaussianBlur(gray, (5, 5), 0)
    
    rectKernel = cv2.getStructuringElement(cv2.MORPH_RECT, (13, 5))
    blackhat = cv2.morphologyEx(gray, cv2.MORPH_BLACKHAT, rectKernel)

    # 3. Edges & Closing
    gradX = cv2.Sobel(blackhat, ddepth=cv2.CV_32F, dx=1, dy=0, ksize=-1)
    gradX = np.absolute(gradX)
    (minVal, maxVal) = (np.min(gradX), np.max(gradX))
    gradX = (255 * ((gradX - minVal) / (maxVal - minVal))).astype("uint8")
    gradX = cv2.morphologyEx(gradX, cv2.MORPH_CLOSE, rectKernel)
    
    # 4. Threshold & Connect
    thresh = cv2.threshold(gradX, 0, 255, cv2.THRESH_BINARY | cv2.THRESH_OTSU)[1]
    
    lineKernel = cv2.getStructuringElement(cv2.MORPH_RECT, (50, 2))
    thresh = cv2.morphologyEx(thresh, cv2.MORPH_CLOSE, lineKernel)
    thresh = cv2.erode(thresh, None, iterations=2)
    
    # 5. Find Contours
    cnts = cv2.findContours(thresh.copy(), cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    cnts = imutils.grab_contours(cnts)
    
    mrz_crops = []
    
    # 6. Process Contours using Rotated Rect
    for c in cnts:
        rect = cv2.minAreaRect(c)
        (center, size, angle) = rect
        width, height = size

        # --- FIX: Prevent Division by Zero ---
        if width == 0 or height == 0:
            continue

        if width < height: width, height = height, width
        ar = width / float(height)

        if ar > 10 and width > (processing_img.shape[1] * 0.5):
            scaled_center = (center[0] * ratio, center[1] * ratio)
            scaled_size = (size[0] * ratio, size[1] * ratio)
            scaled_rect = (scaled_center, scaled_size, angle)

            # A. STRAIGHTEN
            straight_crop = crop_and_straighten(original, scaled_rect)
            
            # B. TIGHTEN
            final_crop = trim_horizontal_padding(straight_crop, padding=3)
            
            mrz_crops.append(final_crop)

            # --- Visualization ---
            box = cv2.boxPoints(scaled_rect)
            box = np.int32(box) # Using int32 for compatibility
            
            cv2.drawContours(original, [box], 0, (0, 255, 0), 2)
    
    return original, mrz_crops

# --- Execution ---
input_file = "image_6b62e9.jpg" # Replace with your file

try:
    final_debug_img, crops = detect_rotated_mrz(input_file)
    
    if final_debug_img is not None:
        plt.figure(figsize=(10, 6))
        plt.imshow(cv2.cvtColor(final_debug_img, cv2.COLOR_BGR2RGB))
        plt.title("Rotated Detectors")
        plt.axis('off')
        plt.show()

        if crops:
            plt.figure(figsize=(15, 4))
            for i, crop in enumerate(crops):
                plt.subplot(1, len(crops), i+1)
                plt.imshow(cv2.cvtColor(crop, cv2.COLOR_BGR2RGB))
                plt.title(f"Line {i+1}")
                plt.axis('off')
            plt.show()
        else:
            print("No MRZ found.")

except Exception as e:
    print(f"Error: {e}")
